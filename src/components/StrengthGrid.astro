---
import type { StrengthCategory } from '../data/resume';

interface Props {
  items: StrengthCategory[];
  lang: 'en' | 'zh';
}

const { items, lang } = Astro.props;
---

<div class="advantage-grid">
  {items.map(category => (
    <div class="advantage-item">
      <span class="advantage-label" data-lang={lang}>{category.label}</span>
      <div class="tags">
        {category.tags.map(tag => (
          <span class:list={['tag', { highlight: tag.highlight }]}>{tag.text}</span>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .advantage-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .advantage-item {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .advantage-label {
    font-size: 13px;
    color: #888;
    white-space: nowrap;
    text-align: right;
    flex-shrink: 0;
    min-width: 110px;
  }

  .advantage-label[data-lang="zh"] { min-width: 90px; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-size: 12px;
    color: #555;
    background: #f4f4f5;
    border: 1px solid #e5e5e5;
    padding: 3px 12px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .tag.highlight {
    color: #2c2c2c;
    background: #f0f0f0;
    border-color: #ccc;
    font-weight: 500;
  }
</style>

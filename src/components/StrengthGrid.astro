---
import type { StrengthCategory } from '../data/resume';

interface Props {
  items: StrengthCategory[];
  lang: 'en' | 'zh';
}

const { items, lang } = Astro.props;
---

<div class="strengths">
  {items.map((category) => (
    <div class="strength-row">
      <span class="strength-label" data-lang={lang}>{category.label}</span>
      <div class="strength-tags">
        {category.tags.map((tag) => (
          <span class:list={['s-tag', { highlight: tag.highlight }]}>{tag.text}</span>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .strengths {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .strength-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 16px;
    align-items: start;
  }

  .strength-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding-top: 6px;
    white-space: nowrap;
  }
  .strength-label[data-lang="zh"] {
    text-transform: none;
    letter-spacing: 0.06em;
    font-family: 'Geist', -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  }

  .strength-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .s-tag {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-soft);
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition: all 0.2s;
  }
  .s-tag.highlight {
    color: var(--ink);
    border-color: var(--ink);
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .strength-row { grid-template-columns: 1fr; gap: 6px; }
    .strength-label { padding-top: 0; font-size: 10.5px; }
  }

  @media print {
    .s-tag { background: transparent !important; color: #333 !important; border-color: #aaa !important; }
    .s-tag.highlight { color: #000 !important; border-color: #000 !important; }
  }
</style>

---
import type { ResumeData } from '../data/resume';
import ExperienceItem from './ExperienceItem.astro';
import StrengthGrid from './StrengthGrid.astro';
// import HighlightStack from './HighlightStack.astro'; // re-enable when restoring the Highlights block below
import Icon from './Icon.astro';

interface Props {
  data: ResumeData;
  lang: 'en' | 'zh';
}

const { data, lang } = Astro.props;

// Identity pillars — the core of "who I am" surfaced as iconified pills.
// Order matters: location anchors the strip, then primary identity, then
// adjacent specialties. Per-language labels keep the tone native.
const identityCopy =
  lang === 'en'
    ? ['Shenzhen', 'Backend', 'AI Agents', 'Full-Stack', 'Data Governance']
    : ['深圳', '后端', 'AI Agent', '全栈', '数据治理'];
const identityIcons = ['map-pin', 'server', 'bot', 'code-2', 'database'] as const;

const heroKicker = lang === 'en' ? '// resume' : '// 简历';
---

<section class="resume-hero fade">
  <p class="kicker">{heroKicker}</p>
  <h1>{data.name}</h1>

  <div class="identity-strip">
    {identityCopy.map((label, i) => (
      <span class:list={['pill', { 'pill--primary': i === 1 || i === 2 }]}>
        <Icon name={identityIcons[i]} size={13} />
        <span>{label}</span>
      </span>
    ))}
  </div>

  <div class="contact-strip">
    {data.meta.map((item) => <span class="contact-item">{item}</span>)}
    {data.contacts.map((c) => (
      c.type === 'email' ? (
        <a class="contact-item is-link" href={`mailto:${c.value}`}>
          <Icon name="mail" size={12} />
          <span>{c.value}</span>
        </a>
      ) : (
        <span class="contact-item">
          <Icon name="phone" size={12} />
          <span>{c.value}</span>
        </span>
      )
    ))}
  </div>
</section>

<section class="section fade">
  <h2>{data.sectionTitles.education}</h2>
  <div class="body">
    <div class="education">
      <div class="edu-main">
        <div class="edu-row">
          <img src={data.education.schoolLogo} alt={data.education.school} class="school-logo" />
          <span class="school">{data.education.school}</span>
          <span class="degree">{data.education.degree}</span>
          <span class="college">{data.education.college}</span>
        </div>
        {data.education.major && <p class="major">{data.education.major}</p>}
      </div>
      <span class="edu-date">{data.education.date}</span>
    </div>
  </div>
</section>

<section class="section fade">
  <h2>{data.sectionTitles.strengths}</h2>
  <div class="body">
    <StrengthGrid items={data.strengths} lang={lang} />
  </div>
</section>

{/*
  Highlights section temporarily hidden by request. The data still lives in
  resume.ts (`highlights` field) and the HighlightStack component is intact —
  to re-enable, restore this block and re-import HighlightStack at the top.

  <section class="section fade">
    <h2>{data.sectionTitles.highlights}</h2>
    <div class="body">
      <HighlightStack items={data.highlights} lang={lang} />
    </div>
  </section>
*/}

<section class="section fade">
  <h2>{data.sectionTitles.experience}</h2>
  <div class="body">
    <div class="timeline">
      {data.experience.map((entry, i) => (
        <ExperienceItem
          entry={entry}
          isFirst={i === 0}
          isLast={i === data.experience.length - 1}
        />
      ))}
    </div>
  </div>
</section>

<style>
  /* Identity strip — iconified pills, slightly elevated. Two pills are marked
     `pill--primary` (Backend + AI Agents) to anchor the rest visually. */
  .identity-strip {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 12px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--ink-soft);
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    border-radius: 8px;
    letter-spacing: 0.01em;
    transition: all 0.2s;
  }
  .pill svg {
    color: var(--ink-mute);
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .pill:hover {
    color: var(--ink);
    border-color: var(--ink);
  }
  .pill:hover svg { color: var(--ink); }

  .pill--primary {
    color: var(--ink);
    border-color: var(--ink);
    font-weight: 500;
  }
  .pill--primary svg { color: var(--accent); }

  /* Contact strip — facts and reach-me lines, smaller and quieter. */
  .contact-strip {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 16px;
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-mute);
    letter-spacing: 0.01em;
  }
  .contact-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .contact-item svg {
    color: var(--ink-mute);
    flex-shrink: 0;
  }
  .contact-item.is-link {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-item.is-link:hover { color: var(--accent); }
  .contact-item.is-link:hover svg { color: var(--accent); }

  .timeline { display: flex; flex-direction: column; }

  .education {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 8px 16px;
  }
  .edu-main {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .edu-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .school-logo {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }
  .school {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
  }
  .degree {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--ink-soft);
    border: 1px solid var(--rule);
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--bg-elev);
  }
  .college {
    font-size: 13.5px;
    color: var(--ink-soft);
  }
  .major {
    font-size: 12.5px;
    color: var(--ink-mute);
    font-family: 'Geist Mono', monospace;
    letter-spacing: 0.01em;
    margin-left: 32px; /* line up with the school name (logo width + gap) */
  }
  .edu-date {
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    color: var(--ink-mute);
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 720px) {
    .identity-strip { gap: 6px; }
    .pill { padding: 6px 10px; font-size: 11px; }
    .contact-strip { gap: 4px 12px; }
    .education { flex-direction: column; align-items: flex-start; }
    .major { margin-left: 0; }
  }

  @media print {
    .pill { background: transparent !important; border-color: #aaa !important; color: #333 !important; }
    .pill--primary { color: #000 !important; border-color: #000 !important; }
    .pill svg, .pill--primary svg { color: #333 !important; }
    .contact-strip { color: #333 !important; }
    .school { color: #000 !important; }
    .degree { background: transparent !important; border-color: #aaa !important; color: #333 !important; }
  }
</style>

---
// Combined resume — English on top, Chinese below, sharing one page chrome.
import ExperienceItem from '../../components/ExperienceItem.astro';
import StrengthGrid from '../../components/StrengthGrid.astro';
import { en, zh } from '../../data/resume';

const sections = [
  { lang: 'en', data: en },
  { lang: 'zh', data: zh },
] as const;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resume — Shane Chang</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", "Segoe UI", Roboto, sans-serif;
      color: #2c2c2c;
      background: #fafafa;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 820px;
      margin: 40px auto;
      background: #fff;
      padding: 60px 64px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }

    /* Spacer + rule between EN and ZH blocks */
    .resume + .resume {
      margin-top: 56px;
      padding-top: 56px;
      border-top: 1px solid #e5e5e5;
    }

    /* ===== Per-resume header ===== */
    .header {
      text-align: center;
      padding-bottom: 32px;
      border-bottom: 2px solid #2c2c2c;
    }

    .header h1 {
      font-size: 32px;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .resume[data-lang="en"] .header h1 { letter-spacing: 4px; }
    .resume[data-lang="zh"] .header h1 { letter-spacing: 6px; }

    .meta {
      font-size: 14px;
      color: #666;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 6px 20px;
    }

    .meta span::before {
      content: '';
      display: inline-block;
      width: 3px;
      height: 3px;
      background: #999;
      border-radius: 50%;
      vertical-align: middle;
      margin-right: 8px;
    }
    .meta span:first-child::before { display: none; }

    /* ===== Section heading ===== */
    .section { margin-top: 36px; }

    .section-title {
      font-size: 17px;
      font-weight: 600;
      padding-bottom: 10px;
      border-bottom: 1px solid #ddd;
      margin-bottom: 20px;
      position: relative;
    }

    .section-title::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 48px;
      height: 2px;
      background: #2c2c2c;
    }

    .resume[data-lang="en"] .section-title { text-transform: uppercase; letter-spacing: 2px; }
    .resume[data-lang="zh"] .section-title { letter-spacing: 3px; }

    /* ===== Education item ===== */
    .edu-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 4px;
    }

    .school { font-size: 15px; font-weight: 600; }
    .school-logo {
      width: 22px;
      height: 22px;
      object-fit: contain;
      vertical-align: middle;
      margin-right: 6px;
      position: relative;
      top: -1px;
    }
    .degree { font-size: 13px; color: #888; margin-left: 12px; }
    .major  { font-size: 13px; color: #666; margin-left: 8px; }
    .date   { font-size: 13px; color: #999; }

    /* ===== Print: each language on its own page sheet ===== */
    @media print {
      body { background: #fff; }
      .container { box-shadow: none; margin: 0; padding: 40px 48px; }
      .resume + .resume { page-break-before: always; }
    }

    @media (max-width: 640px) {
      .container { margin: 0; padding: 32px 24px; }
      .header h1 { font-size: 26px; }
    }
  </style>
</head>
<body>
  <main class="container">
    {sections.map(({ lang, data }) => (
      <article class="resume" data-lang={lang} lang={lang}>
        <header class="header">
          <h1>{data.name}</h1>
          <div class="meta">
            {data.meta.map(item => <span>{item}</span>)}
          </div>
        </header>

        <section class="section">
          <h2 class="section-title">{data.sectionTitles.education}</h2>
          <div class="edu-item">
            <div>
              <img src={data.education.schoolLogo} alt={data.education.school} class="school-logo">
              <span class="school">{data.education.school}</span>
              <span class="degree">{data.education.degree}</span>
              <span class="major">{data.education.major}</span>
            </div>
            <span class="date">{data.education.date}</span>
          </div>
        </section>

        <section class="section">
          <h2 class="section-title">{data.sectionTitles.experience}</h2>
          {data.experience.map((entry, i) => (
            <ExperienceItem entry={entry} isLast={i === data.experience.length - 1} />
          ))}
        </section>

        <section class="section">
          <h2 class="section-title">{data.sectionTitles.strengths}</h2>
          <StrengthGrid items={data.strengths} lang={lang} />
        </section>
      </article>
    ))}
  </main>
</body>
</html>

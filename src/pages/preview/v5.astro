---
// V5 — Studio. Merge of V2 (Geist typography, structure) and V3 (aurora atmosphere, glass cards, cursor glow).
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shane Chang — Studio</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #08090e;
      --bg-elev: #0d0f15;
      --surface: rgba(255,255,255,0.04);
      --surface-hi: rgba(255,255,255,0.07);
      --border: rgba(255,255,255,0.07);
      --border-hi: rgba(255,255,255,0.14);
      --text: #ededf2;
      --text-soft: #a8a8b8;
      --text-mute: #5e5e6e;
      --accent: #ff7e5c;
      --accent-2: #c2a8ff;
      --accent-3: #5cc8ff;
      --grid: rgba(255,255,255,0.025);
      --sans: 'Geist', -apple-system, sans-serif;
      --mono: 'Geist Mono', monospace;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      -webkit-font-smoothing: antialiased;
    }

    body {
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
      background: transparent;
      background-image:
        linear-gradient(var(--grid) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid) 1px, transparent 1px);
      background-size: 64px 64px;
    }

    /* Subtle aurora behind everything */
    .aurora {
      position: fixed;
      inset: -10% -10%;
      z-index: -2;
      filter: blur(120px);
      opacity: 0.45;
      pointer-events: none;
    }
    .aurora .blob { position: absolute; border-radius: 50%; mix-blend-mode: screen; }
    .aurora .blob-1 {
      width: 36%; height: 38%; top: -8%; left: 5%;
      background: var(--accent);
      animation: drift-1 26s ease-in-out infinite;
    }
    .aurora .blob-2 {
      width: 32%; height: 42%; top: 0; right: 0;
      background: var(--accent-2);
      animation: drift-2 32s ease-in-out infinite;
      opacity: 0.65;
    }
    .aurora .blob-3 {
      width: 40%; height: 30%; bottom: 5%; left: 30%;
      background: var(--accent-3);
      animation: drift-3 38s ease-in-out infinite;
      opacity: 0.4;
    }

    @keyframes drift-1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(8%, 12%) scale(1.1); }
      66% { transform: translate(-6%, 8%) scale(0.95); }
    }
    @keyframes drift-2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-10%, 8%) scale(1.05); }
      66% { transform: translate(6%, -8%) scale(1.1); }
    }
    @keyframes drift-3 {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(10%, -10%); }
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: -1;
      background: radial-gradient(ellipse at 50% 60%, transparent 0%, rgba(8,9,14,0.55) 70%, rgba(8,9,14,0.85) 100%);
      pointer-events: none;
    }

    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 32px 32px 80px;
      position: relative;
    }

    /* Top nav */
    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      margin-bottom: 64px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text);
      font-weight: 500;
    }

    .logo .dot {
      width: 7px; height: 7px;
      background: var(--accent);
      border-radius: 50%;
      box-shadow: 0 0 8px var(--accent);
      animation: ping 3s ease-in-out infinite;
    }

    @keyframes ping {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.8); }
    }

    .nav-actions { display: flex; gap: 22px; align-items: center; }

    .nav a {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text-soft);
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: color 0.2s;
    }
    .nav a:hover { color: var(--text); }

    /* Hero */
    .hero {
      margin-bottom: 80px;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 32px;
      align-items: center;
    }

    .hero-portrait {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      object-fit: cover;
      border: 1px solid var(--border-hi);
      box-shadow:
        0 0 0 4px rgba(255,255,255,0.02),
        0 12px 32px -8px rgba(255,126,92,0.25);
    }

    .hero-text { min-width: 0; }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 100px;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--text-soft);
      letter-spacing: 0.04em;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      margin-bottom: 18px;
      text-transform: uppercase;
    }

    .pill .status {
      width: 5px; height: 5px;
      background: #4ade80;
      border-radius: 50%;
      box-shadow: 0 0 6px #4ade80;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    .hero h1 {
      font-weight: 600;
      font-size: clamp(40px, 6vw, 64px);
      line-height: 1;
      letter-spacing: -0.035em;
      margin-bottom: 14px;
      background: linear-gradient(180deg, var(--text) 30%, rgba(237,237,242,0.6) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero .tagline {
      font-size: 15px;
      line-height: 1.55;
      color: var(--text-soft);
      max-width: 520px;
      font-weight: 300;
    }

    .hero .tagline strong {
      font-weight: 500;
      background: linear-gradient(120deg, var(--accent), #ffb37e);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    /* Section header */
    .section {
      margin-bottom: 56px;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 20px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border);
    }

    .section-head h2 {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      color: var(--text-mute);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .section-head .meta-info {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--text-mute);
      letter-spacing: 0.04em;
    }

    /* Selected work grid */
    .work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .work-card {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 10px;
      text-decoration: none;
      color: inherit;
      padding: 12px;
      border-radius: 14px;
      background: linear-gradient(180deg, var(--surface), rgba(255,255,255,0.005));
      border: 1px solid var(--border);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
      overflow: hidden;
    }

    .work-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(500px circle at var(--mx, 50%) var(--my, 50%), rgba(255,126,92,0.10), transparent 40%);
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
    }
    .work-card:hover { transform: translateY(-2px); border-color: var(--border-hi); }
    .work-card:hover::before { opacity: 1; }

    .work-cover {
      aspect-ratio: 4/3;
      border-radius: 8px;
      overflow: hidden;
      position: relative;
    }

    .work-cover img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .work-card:hover .work-cover img { transform: scale(1.05); }

    .work-meta {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 4px 6px 6px;
    }

    .work-title {
      font-size: 13px;
      font-weight: 500;
      letter-spacing: -0.005em;
    }

    .work-tags {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--text-mute);
      letter-spacing: 0.02em;
    }

    /* Read / Reading list — glass cards */
    .read-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .read-card {
      position: relative;
      padding: 22px;
      border-radius: 14px;
      background: linear-gradient(180deg, var(--surface), rgba(255,255,255,0.005));
      border: 1px solid var(--border);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      text-decoration: none;
      color: inherit;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .read-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(500px circle at var(--mx, 50%) var(--my, 50%), rgba(255,126,92,0.08), transparent 40%);
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
    }
    .read-card:hover { transform: translateY(-2px); border-color: var(--border-hi); }
    .read-card:hover::before { opacity: 1; }

    .read-card .label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--text-mute);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .read-card .label img {
      width: 12px; height: 12px;
      filter: invert(1) brightness(0.8);
    }

    .read-card .title {
      font-size: 18px;
      font-weight: 500;
      margin-bottom: 4px;
      letter-spacing: -0.015em;
    }

    .read-card .desc {
      font-size: 12px;
      color: var(--text-soft);
      line-height: 1.5;
    }

    .read-card .arrow {
      position: absolute;
      top: 18px;
      right: 18px;
      color: var(--text-mute);
      transition: all 0.3s;
      font-family: var(--mono);
      font-size: 13px;
    }
    .read-card:hover .arrow { color: var(--accent); transform: translate(2px, -2px); }

    /* Social rail */
    .social-rail {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 10px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    .social-rail a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 8px;
      font-size: 12px;
      color: var(--text-soft);
      text-decoration: none;
      transition: all 0.2s;
      font-family: var(--mono);
      letter-spacing: 0.01em;
    }

    .social-rail a:hover {
      background: var(--surface-hi);
      color: var(--text);
    }

    .social-rail a img {
      width: 13px; height: 13px;
      filter: invert(1) brightness(0.8);
    }

    /* Footer */
    .foot {
      margin-top: 56px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-mute);
    }

    .foot a { color: var(--text-mute); text-decoration: none; transition: color 0.2s; }
    .foot a:hover { color: var(--text); }

    /* Reveal */
    .reveal { opacity: 0; transform: translateY(12px); animation: rise 0.9s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
    .reveal:nth-of-type(1) { animation-delay: 0.05s; }
    .reveal:nth-of-type(2) { animation-delay: 0.16s; }
    .reveal:nth-of-type(3) { animation-delay: 0.28s; }
    .reveal:nth-of-type(4) { animation-delay: 0.4s; }
    .reveal:nth-of-type(5) { animation-delay: 0.52s; }
    .reveal:nth-of-type(6) { animation-delay: 0.64s; }
    .reveal:nth-of-type(7) { animation-delay: 0.76s; }
    @keyframes rise { to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 720px) {
      .page { padding: 24px 20px 56px; }
      .nav { margin-bottom: 40px; }
      .hero {
        grid-template-columns: 1fr;
        gap: 20px;
        margin-bottom: 56px;
      }
      .hero-portrait { width: 80px; height: 80px; }
      .hero h1 { font-size: clamp(36px, 11vw, 56px); }
      .work-grid { grid-template-columns: 1fr 1fr; }
      .read-grid { grid-template-columns: 1fr; }
      .foot { flex-direction: column; gap: 8px; }
    }
    @media (max-width: 480px) {
      .work-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="aurora">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <main class="page">
    <nav class="nav reveal">
      <div class="logo">
        <span class="dot"></span>
        <span>shane-chang/studio</span>
      </div>
      <div class="nav-actions">
        <a href="/resume/en/">Resume</a>
        <a href="#contact">Connect</a>
      </div>
    </nav>

    <section class="hero reveal">
      <img class="hero-portrait" src="https://picsum.photos/seed/sc-portrait/200/200" alt="Shane Chang" />
      <div class="hero-text">
        <span class="pill">
          <span class="status"></span>
          Available for select work
        </span>
        <h1>Shane Chang.</h1>
        <p class="tagline">Software engineer based in Shenzhen. <strong>Backend systems</strong>, internal platforms, and the occasional quiet tool — four years in, half spent at Tencent.</p>
      </div>
    </section>

    <section class="section reveal">
      <div class="section-head">
        <h2>Selected Work</h2>
        <span class="meta-info">2022 — 2026</span>
      </div>
      <div class="work-grid">
        <a class="work-card" href="/resume/en/">
          <div class="work-cover"><img src="https://picsum.photos/seed/sc-work-1/600/450" alt="" loading="lazy"/></div>
          <div class="work-meta">
            <span class="work-title">Internal efficiency platform</span>
            <span class="work-tags">2025 · Python · Tools</span>
          </div>
        </a>
        <a class="work-card" href="/resume/en/">
          <div class="work-cover"><img src="https://picsum.photos/seed/sc-work-2/600/450" alt="" loading="lazy"/></div>
          <div class="work-meta">
            <span class="work-title">Cross-border WMS</span>
            <span class="work-tags">2024 · Java · Logistics</span>
          </div>
        </a>
        <a class="work-card" href="/resume/en/">
          <div class="work-cover"><img src="https://picsum.photos/seed/sc-work-3/600/450" alt="" loading="lazy"/></div>
          <div class="work-meta">
            <span class="work-title">Brand-protection pipeline</span>
            <span class="work-tags">2022 · Python · Tencent</span>
          </div>
        </a>
      </div>
    </section>

    <section class="section reveal">
      <div class="section-head">
        <h2>Reading Room</h2>
        <span class="meta-info">writing · 中文 · video</span>
      </div>
      <div class="read-grid">
        <a class="read-card" href="https://blog.example.com" target="_blank">
          <div class="label"><img src="/assets/hashnode.svg" alt=""> Writing</div>
          <div class="title">Personal blog</div>
          <div class="desc">Notes on backend, internal platforms, and craft.</div>
          <span class="arrow">↗</span>
        </a>
        <a class="read-card" href="https://juejin.cn/user/shanezchang" target="_blank">
          <div class="label"><img src="/assets/juejin.svg" alt=""> 中文</div>
          <div class="title">稀土掘金</div>
          <div class="desc">中文技术文章与笔记同步。</div>
          <span class="arrow">↗</span>
        </a>
        <a class="read-card" href="https://space.bilibili.com/shanezchang" target="_blank">
          <div class="label"><img src="/assets/bilibili.svg" alt=""> Video</div>
          <div class="title">Bilibili</div>
          <div class="desc">视频与技术 vlog。</div>
          <span class="arrow">↗</span>
        </a>
        <a class="read-card" href="/resume/en/">
          <div class="label"><img src="/assets/favicon.svg" alt=""> Doc</div>
          <div class="title">Resume / 简历</div>
          <div class="desc">EN · 中文 — 四年工程经验。</div>
          <span class="arrow">→</span>
        </a>
      </div>
    </section>

    <section class="section reveal" id="contact">
      <div class="section-head">
        <h2>Found at</h2>
        <span class="meta-info">@shanezchang</span>
      </div>
      <div class="social-rail">
        <a href="https://github.com/shanezchang" target="_blank"><img src="/assets/github.svg" alt=""> GitHub</a>
        <a href="https://linkedin.com/in/shanezchang" target="_blank"><img src="/assets/linkedin.svg" alt=""> LinkedIn</a>
        <a href="https://x.com/shanezchang" target="_blank"><img src="/assets/x.svg" alt=""> X</a>
        <a href="https://youtube.com/@shanezchang" target="_blank"><img src="/assets/youtube.svg" alt=""> YouTube</a>
        <a href="https://instagram.com/shanezchang" target="_blank"><img src="/assets/instagram.svg" alt=""> Instagram</a>
        <a href="https://t.me/shanezchang" target="_blank"><img src="/assets/telegram.svg" alt=""> Telegram</a>
      </div>
    </section>

    <footer class="foot reveal">
      <span>// 22.54° N · Shenzhen · 2026</span>
      <a href="mailto:shane.z.chang@hotmail.com">shane.z.chang@hotmail.com</a>
    </footer>
  </main>

  <script>
    document.querySelectorAll('.work-card, .read-card').forEach(c => {
      c.addEventListener('mousemove', e => {
        const r = c.getBoundingClientRect();
        c.style.setProperty('--mx', (e.clientX - r.left) + 'px');
        c.style.setProperty('--my', (e.clientY - r.top) + 'px');
      });
    });
  </script>
</body>
</html>
